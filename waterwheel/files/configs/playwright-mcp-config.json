{
  "browser": {
    "browserName": "chromium",
    "launchOptions": {
      "args": [
        "--disable-gpu",
        "--disable-setuid-sandbox",
        "--disable-features=GCMRegistration,OptimizationHints,MediaRouter,DialMediaRouteProvider"
      ]
    },
    "snapshot": {
      "mode": "none"
    }
  }
}

